---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const guides = (await getCollection('guides')).filter((g) => !g.data.draft);
const featured = [
  { id: 'lHhRhPV--G0', title: 'Flutter in 100 Seconds', channel: 'Fireship' },
  { id: 'VPvVD8t02U8', title: 'Flutter Course for Beginners (37-hour)', channel: 'freeCodeCamp' },
  { id: 'CzRQ9mnmh44', title: 'The Complete Dart & Flutter Developer Course', channel: 'Tutorials' },
  { id: 'Zp7VKVhirmw', title: 'Riverpod 2.0 — Complete Guide', channel: 'Code With Andrea' },
  { id: 'J2iFYZUabVM', title: 'State Management with Riverpod', channel: 'Code With Andrea' },
];
const channels = [
  { name: 'Flutter (chính thức)', url: 'https://www.youtube.com/@flutterdev', focus: 'Bản phát hành · Widget of the Week' },
  { name: 'Fireship', url: 'https://www.youtube.com/@Fireship', focus: 'Video giải thích nhanh, nhiều view' },
  { name: 'Code With Andrea', url: 'https://www.youtube.com/@CodeWithAndrea', focus: 'Kiến trúc · Riverpod' },
  { name: 'HeyFlutter.com', url: 'https://www.youtube.com/@HeyFlutter', focus: 'Hướng dẫn gói & widget' },
  { name: 'The Flutter Way', url: 'https://www.youtube.com/@TheFlutterWay', focus: 'Clone UI & thiết kế' },
  { name: 'Reso Coder', url: 'https://www.youtube.com/@ResoCoder', focus: 'TDD · clean architecture' },
  { name: 'Flutter Mapp', url: 'https://www.youtube.com/@FlutterMapp', focus: 'Mẹo · gói' },
  { name: 'Vandad Nahavandipoor', url: 'https://www.youtube.com/@vandadnp', focus: 'Khóa học dài' },
  { name: 'Rivaan Ranawat', url: 'https://www.youtube.com/@RivaanRanawat', focus: 'Xây app full-stack' },
  { name: 'Mitch Koko', url: 'https://www.youtube.com/@createdbykoko', focus: 'UI xu hướng & AI' },
  { name: 'Tadas Petra', url: 'https://www.youtube.com/@TadasPetra', focus: 'Phân tích gói · tin tức' },
  { name: 'The Net Ninja', url: 'https://www.youtube.com/@NetNinja', focus: 'Series Flutter cho người mới' },
];
const topics = ['flutter ai', 'flutter animation', 'flutter state management riverpod', 'flutter ui design', 'flutter firebase', 'flutter clean architecture', 'flutter bloc', 'flutter gemini ai'];
const yt = (q) => 'https://www.youtube.com/results?search_query=' + encodeURIComponent(q) + '&sp=CAM%253D';
---
<BaseLayout lang="vi" title="Flutter trên YouTube — xu hướng & kênh hàng đầu | FlutterCook" description="Tuyển tập nội dung Flutter hay nhất trên YouTube: video tiêu biểu, các nhà sáng tạo nên theo dõi, và tìm kiếm xu hướng trực tiếp theo chủ đề.">
  <main class="wrap">
    <section class="hero">
      <div class="kicker">Xu hướng video</div>
      <h1 class="serif">Flutter trên <i>YouTube</i>.</h1>
      <p>Những video và nhà sáng tạo cộng đồng Flutter đang xem — hướng dẫn tiêu biểu, các kênh đáng theo dõi, và tìm kiếm xu hướng trực tiếp theo chủ đề.</p>
    </section>
    <section class="sec">
      <h2 class="serif">Video <i>tiêu biểu</i></h2>
      <p class="lead">Giới thiệu và hướng dẫn kinh điển, nhiều view — điểm khởi đầu nhanh cho mọi chủ đề.</p>
      <div class="vgrid">
        {featured.map((v) => (
          <a class="vcard" href={`https://www.youtube.com/watch?v=${v.id}`} target="_blank" rel="noopener">
            <div class="thumb">
              <img loading="lazy" src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`} alt={v.title} width="480" height="360" />
              <span class="play">▶</span>
            </div>
            <div class="vmeta"><b>{v.title}</b><small>{v.channel}</small></div>
          </a>
        ))}
      </div>
    </section>
    <section class="sec">
      <h2 class="serif">Tìm kiếm <i>xu hướng</i></h2>
      <p class="lead">Mở các video mới nhất cho một chủ đề — xếp theo ngày đăng, ngay trên YouTube.</p>
      <div class="filterbar">
        {topics.map((t) => <a class="btn" href={yt(t)} target="_blank" rel="noopener">{t.replace('flutter ', '')} ↗</a>)}
      </div>
    </section>
    <section class="sec">
      <h2 class="serif">Lộ trình học <i>YouTube</i></h2>
      <p class="lead">Các hướng dẫn biến video xu hướng thành lộ trình — theo chủ đề.</p>
      <div class="grid">
        {guides.map((g) => (
          <a class="card" href={`/vi/guides/${g.id}/`}>
            <span class="cat">{g.data.topic || 'Guide'}</span>
            <h3 style="font-family:inherit;font-size:15px">{g.data.title}</h3>
            <p>{g.data.description}</p>
          </a>
        ))}
      </div>
    </section>
    <section class="sec">
      <h2 class="serif">Kênh <i>nên theo dõi</i></h2>
      <p class="lead">Nơi FlutterCook theo dõi điều sắp tới.</p>
      <div class="grid">
        {channels.map((c) => (
          <a class="card" href={c.url} target="_blank" rel="noopener">
            <span class="cat">YouTube</span>
            <h3>{c.name}</h3>
            <p>{c.focus}</p>
          </a>
        ))}
      </div>
    </section>
  </main>
  <style>
    .vgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
    .vcard{background:var(--panel);border:1px solid var(--line);border-radius:16px;overflow:hidden;display:block;transition:border-color .2s,transform .2s}
    .vcard:hover{border-color:var(--accent);transform:translateY(-2px)}
    .thumb{position:relative;aspect-ratio:16/9;overflow:hidden;background:#000}
    .thumb img{width:100%;height:100%;object-fit:cover;display:block}
    .thumb .play{position:absolute;inset:0;display:grid;place-items:center;font-size:34px;color:#fff;background:rgba(0,0,0,.25);text-shadow:0 2px 10px rgba(0,0,0,.6)}
    .vmeta{padding:12px 14px}
    .vmeta b{display:block;font-size:14px;color:var(--ink);line-height:1.3}
    .vmeta small{color:var(--accent);font-size:12px}
  </style>
</BaseLayout>
