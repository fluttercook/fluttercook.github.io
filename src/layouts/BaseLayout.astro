---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const {
  title,
  description = 'FlutterCook — 500 hands-on guides to the best open-source Flutter libraries, UI kits, and apps for mobile app development. Every recipe ships with real GitHub trend data, install steps, alternatives, and an FAQ.',
  keywords = [],
  ogType = 'website',
  image = '/og-default.svg',
  datePublished,
  dateModified,
  jsonLd = [],
  lang = 'en',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const kw = Array.isArray(keywords) ? keywords.join(', ') : keywords;
const graphs = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
// hreflang alternates: derive the shared canonical path (strip /vi) then build both.
const basePath = Astro.url.pathname.replace(/^\/vi(?=\/|$)/, '') || '/';
const enHref = new URL(basePath, Astro.site).href;
const viHref = new URL(basePath === '/' ? '/vi/' : `/vi${basePath}`, Astro.site).href;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://www.googletagmanager.com" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {kw && <meta name="keywords" content={kw} />}
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="author" content="FlutterCook" />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="en" href={enHref} />
  <link rel="alternate" hreflang="vi" href={viHref} />
  <link rel="alternate" hreflang="x-default" href={enHref} />
  <meta property="og:site_name" content="FlutterCook" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content={lang === 'vi' ? 'vi_VN' : 'en_US'} />
  <meta property="og:locale:alternate" content={lang === 'vi' ? 'en_US' : 'vi_VN'} />
  <meta property="og:image" content={ogImage} />
  {datePublished && <meta property="article:published_time" content={datePublished} />}
  {dateModified && <meta property="article:modified_time" content={dateModified} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%8D%B3%3C/text%3E%3C/svg%3E" />
  {graphs.map((g) => (
    <script type="application/ld+json" set:html={JSON.stringify(g)} />
  ))}
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-B299VQ6G9N"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-B299VQ6G9N');
  </script>
</head>
<body>
  <div class="wrap"><Header lang={lang} /></div>
  <slot />
  <Footer lang={lang} />
</body>
</html>
