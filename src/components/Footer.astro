---
import { t, localizePath, type Locale } from '../i18n';
const { lang = 'en' as Locale } = Astro.props;
const tr = t(lang);
const year = new Date().getFullYear();
---
<footer class="site">
  <div class="wrap">
    {tr('footer.tagline')} · {year} ·
    <a href="https://github.com/fluttercook" target="_blank" rel="noopener">github.com/fluttercook</a> ·
    <a href={localizePath('/trends', lang)}>{tr('home.trends')}</a>
  </div>
</footer>
